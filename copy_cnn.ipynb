        "t_relative_idx, v_relative_idx=next(gss_val.split(X_cnn_train_val, y_cnn_train_val, groups=groups_train_val))\n",
        "X_cnn_train, y_cnn_train=X_cnn_train_val[t_relative_idx], y_cnn_train_val[t_relative_idx] #appearance of the windows in train or in test\n",
