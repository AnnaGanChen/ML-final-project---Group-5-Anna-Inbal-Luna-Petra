      },
      "outputs": [],
      "source": [
        "diagnosis_lookup = dict(zip(participants['participant_id'], participants['GROUP']))\n",
        "label_lookup = dict(zip(participants['participant_id'], participants['cog_binary']))\n",
        "tier_lookup  = dict(zip(participants['participant_id'], participants['cog_tier']))"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 27,
      "metadata": {
        "id": "2s3LPjhLfmG2"
      },
      "outputs": [],
      "source": [
        "sfreq = 500 #sampling frequancy\n",
        "window_sec = 4 #size of the time window\n",
        "overlap_ratio = 0.5 #overlap between the windows\n",
        "fmin, fmax = 0.5, 12  #12Hz band pass filter for relevant cognitive frequancies\n",
        "\n",
        "window_samples = int(window_sec * sfreq) #the ammount of window samples\n",
        "step = int(window_samples * (1 - overlap_ratio)) #whole window segmentation"
      ]
    },
