        "gss=GroupShuffleSplit(n_splits=1, train_size=0.8, random_state=5) #Train size 80% and GroupShuffleSplit because same subject has about 30 spectograms and we need that all the spectograms of the same subject will be only in train or only in test\n",
        "train_val_idx, test_idx = next(gss.split(X_cnn, y_cnn, groups=groups_cnn))\n",
