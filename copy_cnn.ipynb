      ],
      "source": [
        "# Tensors\n",
        "X_tensor = torch.tensor(X_cnn)\n",
        "y_tensor = torch.tensor(y_cnn).view(-1, 1)\n",
        "y_tier_tensor = torch.tensor(y_tier_cnn).view(-1, 1)\n",
